# STYLE-01..04 de /specs/verification.md, en modo warning-as-error.
root = false

[*.cs]

# Nullable reference warnings -> error (STYLE-04)
dotnet_diagnostic.CS8600.severity = error
dotnet_diagnostic.CS8601.severity = error
dotnet_diagnostic.CS8602.severity = error
dotnet_diagnostic.CS8603.severity = error
dotnet_diagnostic.CS8604.severity = error
dotnet_diagnostic.CS8625.severity = error

# --- Naming rules (STYLE-01, STYLE-02, STYLE-03) ---

dotnet_naming_style.pascal_case.capitalization = pascal_case
dotnet_naming_style.camel_case.capitalization = camel_case
dotnet_naming_style.interface_prefix.capitalization = pascal_case
dotnet_naming_style.interface_prefix.required_prefix = I
dotnet_naming_style.private_field_prefix.capitalization = camel_case
dotnet_naming_style.private_field_prefix.required_prefix = _

dotnet_naming_symbols.types_and_members.applicable_kinds = class, struct, enum, property, method, event
dotnet_naming_symbols.types_and_members.applicable_accessibilities = public, internal, protected, protected_internal, private_protected

dotnet_naming_symbols.interfaces.applicable_kinds = interface

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

# STYLE-03: public/internal types and members -> PascalCase, error
dotnet_naming_rule.types_and_members_pascal_case.symbols = types_and_members
dotnet_naming_rule.types_and_members_pascal_case.style = pascal_case
dotnet_naming_rule.types_and_members_pascal_case.severity = error

# STYLE-01: interfaces start with I, error
dotnet_naming_rule.interfaces_start_with_i.symbols = interfaces
dotnet_naming_rule.interfaces_start_with_i.style = interface_prefix
dotnet_naming_rule.interfaces_start_with_i.severity = error

# STYLE-02: private fields -> _camelCase, error
dotnet_naming_rule.private_fields_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_camel_case.style = private_field_prefix
dotnet_naming_rule.private_fields_camel_case.severity = error
